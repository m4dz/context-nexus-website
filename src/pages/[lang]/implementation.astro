    </section>

    <hr />

    <!-- Knowledge indexing -->
    <section class="section--sm" id="knowledge">
      <h2>{lang === 'fr' ? 'Indexation Knowledge (RAG)' : 'Knowledge indexing (RAG)'}</h2>
      <p>
        {lang === 'fr'
          ? 'Les artefacts Knowledge sont découpés en chunks par concept atomique, puis embarqués dans un index vectoriel. Voir le '
