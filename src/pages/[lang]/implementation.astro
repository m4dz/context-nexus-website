          {lang === 'fr' ? 'registre Knowledge →' : 'Knowledge register →'}
        </a>
      </p>

      <CodeBlock code={codeKnowledgeIndexer} lang="python" filename="context_assembler/knowledge_indexer.py" label="Python" style="margin-top: 1rem" />
    </section>

    <hr />

    <!-- MCP Skills -->
