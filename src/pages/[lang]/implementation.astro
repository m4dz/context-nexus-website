      <h2>{lang === 'fr' ? 'Operations → MCP Skills' : 'Operations → MCP Skills'}</h2>
      <p>
        {lang === 'fr'
          ? 'Les runbooks Operations sont encapsulés comme des outils appelables. Voir le '
          : 'Operations runbooks are encapsulated as callable tools. See the '}
        <a href={`${base}/registers/operations`} style="color: var(--operations)">
          {lang === 'fr' ? 'registre Operations →' : 'Operations register →'}
        </a>
      </p>

      <CodeBlock code={codeSkillsServer} lang="python" filename="skills/server.py" label="Python (MCP Server)" style="margin-top: 1rem" />
    </section>

    <hr />

    <!-- Observability -->
    <section class="section--sm">
      <div class="section-label">{i.observability.label}</div>
      <h2>{i.observability.title}</h2>

      <div class="grid-3" style="margin-top: 1.5rem">
        <div class="feature-card">
          <strong>{i.observability.assembly.title}</strong>
          <p style="margin-top: 0.5rem; font-size: 0.875rem; color: var(--text-subtle)">{i.observability.assembly.desc}</p>
        </div>
        <div class="feature-card">
          <strong>{i.observability.gates.title}</strong>
          <p style="margin-top: 0.5rem; font-size: 0.875rem; color: var(--text-subtle)">{i.observability.gates.desc}</p>
        </div>
        <div class="feature-card">
          <strong>{i.observability.rag.title}</strong>
          <p style="margin-top: 0.5rem; font-size: 0.875rem; color: var(--text-subtle)">{i.observability.rag.desc}</p>
        </div>
      </div>

      <CodeBlock code={codeObservability} lang="python" filename="context_assembler/observability.py" label="Python" style="margin-top: 1.5rem" />
    </section>

    <hr />

    <!-- Multi-agent -->
    <section class="section--sm">
      <div class="section-label">{i.multiagent.label}</div>
      <h2>{i.multiagent.title}</h2>
      <p>{i.multiagent.body}</p>
    </section>

    <hr />

    <!-- Bootstrap -->
    <section class="section--sm" id="bootstrap">
      <div class="section-label">{i.bootstrap.label}</div>
      <h2>{i.bootstrap.title}</h2>
      <p>{i.bootstrap.subtitle}</p>

      <h3 style="margin-top: 2rem">{i.bootstrap.fileTree}</h3>
      <CodeBlock code={codeFileTree} filename={lang === 'fr' ? 'Structure de fichiers' : 'File structure'} />

      <h3 style="margin-top: 2rem">{i.bootstrap.install}</h3>
