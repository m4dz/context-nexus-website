---
import Layout from '../../../layouts/Layout.astro'
import Callout from '../../../components/Callout.astro'
import CrossRefStrip from '../../../components/CrossRefStrip.astro'
import CodeBlock from '../../../components/CodeBlock.astro'
import { useTranslations, type Lang } from '../../../i18n'

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'fr' } }]
}

const { lang } = Astro.params as { lang: Lang }
const t = useTranslations(lang)
const r = t.registers.intent
const base = `/${lang}`

const codeDirective = `\
---
register: intent
level: team
owner: tech-lead
status: active
consumption-mode: system-prompt
last-validated: 2026-06-03
supersedes: null
exception-to: null
---

# Decision Directive — Event-driven indexation

All hotel catalogue updates must transit through a Kafka event
before any write to Elasticsearch. No synchronous catalogue write
to Elasticsearch is allowed in this bounded context.

Acceptance criteria: see Contracts/search-indexation-sla.md
Decision context: Knowledge/decision-contexts/event-driven-indexation.md`

const codeSpec = `\
---
register: intent
consumption-mode: context-injection
---

# Spec SEARCH-89

## Objective
Reduce P95 latency of the results page to under 200ms.

## Acceptance criteria
- [ ] P95 measured on the indexation pipeline: ≤ 200ms
- [ ] No synchronous Elasticsearch write (see Decision Directive /directives/event-driven)
- [ ] Load test: 500 req/s for 5 minutes without degradation`
---

<Layout lang={lang} title={r.meta.title}>

  <div class="page-header" style="border-top: 3px solid var(--intent)">
    <div class="container container--content">
      <div class="page-header__breadcrumb">
        <a href={`/${lang}`}>{lang === 'fr' ? 'Accueil' : 'Home'}</a>
        <span>›</span>
        <a href={`${base}/concepts`}>Concepts</a>
        <span>›</span>
        <span style="color: var(--intent)">{r.header.label}</span>
      </div>
      <div class="badge-row">
        <span class="chip chip--intent">{r.header.sublabel}</span>
        <span class="mode-badge mode-badge--context">Context Injection</span>
        <span class="mode-badge mode-badge--system">System Prompt</span>
      </div>
      <h1 class="page-header__title" style="color: var(--intent)">{r.header.label}</h1>
      <p class="page-header__desc">{r.header.desc}</p>
    </div>
  </div>

  <div class="container container--content">

    <!-- What it contains -->
    <section class="section--sm">
      <h2>{r.what.title}</h2>
      <p set:html={r.what.body} />

      <Callout variant="intent" label="Decision Directive">
        <p>{r.what.decisionDirective.body}</p>
      </Callout>
    </section>

    <hr />

    <!-- Invariant -->
    <section class="section--sm">
      <h2>{r.invariant.title}</h2>
      <Callout variant="warning">
        <p set:html={r.invariant.body} />
      </Callout>
    </section>

    <hr />

    <!-- Human vs AI -->
    <section class="section--sm">
      <h2>{lang === 'fr' ? 'Humains vs Agents IA' : 'Humans vs AI Agents'}</h2>
      <div class="asymmetry">
        <div class="asymmetry__cell asymmetry__cell--human">
          <div class="asymmetry__actor">{r.asymmetry.humanActor}</div>
          <p class="asymmetry__text">{r.asymmetry.humanText}</p>
        </div>
        <div class="asymmetry__cell asymmetry__cell--ai">
          <div class="asymmetry__actor">{r.asymmetry.aiActor}</div>
          <p class="asymmetry__text">{r.asymmetry.aiText}</p>
        </div>
      </div>
      <p style="color: var(--text-subtle); font-style: italic; font-size: 0.875rem">{r.asymmetry.label}</p>
    </section>

    <hr />

    <!-- Consumption modes -->
    <section class="section--sm">
      <h2>{r.consumption.title}</h2>
      <div class="grid-2" style="margin-top: 1rem">
        <div class="feature-card" style="border-top: 2px solid var(--accent)">
          <span class="mode-badge mode-badge--system">System Prompt</span>
          <p style="margin-top: 0.75rem; font-size: 0.9rem" set:html={r.consumption.systemPrompt} />
        </div>
        <div class="feature-card" style="border-top: 2px solid var(--contracts)">
          <span class="mode-badge mode-badge--context">Context Injection</span>
          <p style="margin-top: 0.75rem; font-size: 0.9rem" set:html={r.consumption.context} />
        </div>
      </div>
    </section>

    <hr />

    <!-- Artifact: Decision Directive -->
    <section class="section--sm">
      <h2>{lang === 'fr' ? 'Structure d\'une Decision Directive' : 'Decision Directive structure'}</h2>
      <CodeBlock code={codeDirective} lang="markdown" filename="intent/directives/event-driven-indexation.md" label="YAML + Markdown" />
    </section>

    <hr />

    <!-- Spec artifact -->
    <section class="section--sm">
      <h2>{lang === 'fr' ? 'Structure d\'une spec dans Intent' : 'Spec structure in Intent'}</h2>
      <CodeBlock code={codeSpec} lang="markdown" filename="intent/specs/SEARCH-89.md" label="YAML + Markdown" />
    </section>

    <hr />

    <CrossRefStrip
      lang={lang}
      label={r.crossref.label}
      registers={['knowledge', 'contracts']}
      extra={[
        { label: lang === 'fr' ? 'Exemple → Épisode 1' : 'Example → Episode 1', href: `${base}/example#episode-1` },
        { label: lang === 'fr' ? 'Exemple → Épisode 4' : 'Example → Episode 4', href: `${base}/example#episode-4` },
      ]}
    />

  </div>
</Layout>
