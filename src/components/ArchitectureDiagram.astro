---
---
<svg
  viewBox="0 0 800 470"
  width="100%"
  role="img"
  aria-label="Context Nexus architecture diagram"
  style="display: block; margin: 1.5rem 0; font-family: var(--font-sans);"
>
  <defs>
    <marker id="arch-arrow" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto">
      <polygon points="0 0, 8 3, 0 6" fill="var(--border-strong)" />
    </marker>
  </defs>

  <!-- ── Register boxes ───────────────────────────────────── -->

  <!-- Knowledge -->
  <rect x="10" y="20" width="180" height="70" rx="8"
        fill="var(--knowledge-bg)" stroke="var(--knowledge)" stroke-width="1.5" />
  <text x="100" y="50" text-anchor="middle" font-size="14" font-weight="600" fill="var(--knowledge)">Knowledge</text>
  <text x="100" y="68" text-anchor="middle" font-size="11" fill="var(--text-muted)">RAG · System Prompt</text>

  <!-- Intent -->
  <rect x="210" y="20" width="180" height="70" rx="8"
        fill="var(--intent-bg)" stroke="var(--intent)" stroke-width="1.5" />
  <text x="300" y="50" text-anchor="middle" font-size="14" font-weight="600" fill="var(--intent)">Intent</text>
  <text x="300" y="68" text-anchor="middle" font-size="11" fill="var(--text-muted)">Context Injection</text>

  <!-- Contracts -->
  <rect x="410" y="20" width="180" height="70" rx="8"
        fill="var(--contracts-bg)" stroke="var(--contracts)" stroke-width="1.5" />
  <text x="500" y="50" text-anchor="middle" font-size="14" font-weight="600" fill="var(--contracts)">Contracts</text>
  <text x="500" y="68" text-anchor="middle" font-size="11" fill="var(--text-muted)">System Prompt · Skills</text>

  <!-- Operations -->
  <rect x="610" y="20" width="180" height="70" rx="8"
        fill="var(--operations-bg)" stroke="var(--operations)" stroke-width="1.5" />
  <text x="700" y="50" text-anchor="middle" font-size="14" font-weight="600" fill="var(--operations)">Operations</text>
  <text x="700" y="68" text-anchor="middle" font-size="11" fill="var(--text-muted)">RAG · MCP Skills</text>

  <!-- ── Arrows: registers → Context Assembler ────────────── -->
  <line x1="100" y1="90" x2="100" y2="140" stroke="var(--border-strong)" stroke-width="1.5" marker-end="url(#arch-arrow)" />
  <line x1="300" y1="90" x2="300" y2="140" stroke="var(--border-strong)" stroke-width="1.5" marker-end="url(#arch-arrow)" />
  <line x1="500" y1="90" x2="500" y2="140" stroke="var(--border-strong)" stroke-width="1.5" marker-end="url(#arch-arrow)" />
  <line x1="700" y1="90" x2="700" y2="140" stroke="var(--border-strong)" stroke-width="1.5" marker-end="url(#arch-arrow)" />

  <!-- ── Context Assembler ────────────────────────────────── -->
  <rect x="10" y="140" width="780" height="80" rx="8"
        fill="var(--accent-glow)" stroke="var(--accent)" stroke-width="1.5" />
  <text x="400" y="172" text-anchor="middle" font-size="15" font-weight="600" fill="var(--accent)">Context Assembler</text>
  <text x="400" y="194" text-anchor="middle" font-size="11" fill="var(--text-muted)">Org → BU → Team inheritance · contract validation · TaskBrief assembly</text>

  <!-- ── Arrow: Context Assembler → Agent Runtime ─────────── -->
  <line x1="400" y1="220" x2="400" y2="260" stroke="var(--border-strong)" stroke-width="1.5" marker-end="url(#arch-arrow)" />

  <!-- ── Agent Runtime ────────────────────────────────────── -->
  <rect x="10" y="260" width="780" height="70" rx="8"
        fill="var(--bg-surface)" stroke="var(--border-strong)" stroke-width="1.5" />
  <text x="400" y="290" text-anchor="middle" font-size="15" font-weight="600" fill="var(--text)">Agent Runtime</text>
  <text x="400" y="310" text-anchor="middle" font-size="11" fill="var(--text-muted)">Plan → Tool → Observe loop · session memory</text>

  <!-- ── Fork: Agent Runtime → MCP Skills + Observability ── -->
  <path d="M400,330 V355 H200 V380" stroke="var(--border-strong)" stroke-width="1.5" fill="none" marker-end="url(#arch-arrow)" />
  <path d="M400,330 V355 H600 V380" stroke="var(--border-strong)" stroke-width="1.5" fill="none" marker-end="url(#arch-arrow)" />
  <circle cx="400" cy="355" r="3" fill="var(--border-strong)" />

  <!-- ── MCP Skills ────────────────────────────────────────── -->
  <rect x="10" y="380" width="380" height="70" rx="8"
        fill="var(--bg-surface)" stroke="var(--border-strong)" stroke-width="1.5" />
  <text x="200" y="410" text-anchor="middle" font-size="15" font-weight="600" fill="var(--text)">MCP Skills</text>
  <text x="200" y="430" text-anchor="middle" font-size="11" fill="var(--text-muted)">Operations runbooks · Contracts verification</text>

  <!-- ── Observability ─────────────────────────────────────── -->
  <rect x="410" y="380" width="380" height="70" rx="8"
        fill="var(--bg-surface)" stroke="var(--border-strong)" stroke-width="1.5" />
  <text x="600" y="410" text-anchor="middle" font-size="15" font-weight="600" fill="var(--text)">Observability</text>
  <text x="600" y="430" text-anchor="middle" font-size="11" fill="var(--text-muted)">Langfuse: assembly · quality gates · RAG</text>
</svg>
