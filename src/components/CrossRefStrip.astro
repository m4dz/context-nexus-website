---
import RegisterChip from './RegisterChip.astro'
import { useTranslations, type Lang } from '../i18n'

type Register = 'knowledge' | 'intent' | 'contracts' | 'operations'

interface Props {
  lang: Lang
  label: string
  registers: Register[]
  extra?: Array<{ label: string; href: string }>
}

const { lang, label, registers, extra = [] } = Astro.props

const base = `/${lang}/registers`
const t = useTranslations(lang)

// Register names are framework proper nouns; reuse the nav block's strings
// so a future translation change updates chips and nav together.
const registerLabels: Record<Register, string> = {
  knowledge:  t.nav.knowledge,
  intent:     t.nav.intent,
  contracts:  t.nav.contracts,
  operations: t.nav.operations,
}
---

<div class="crossref">
  <span class="crossref__label">{label}</span>
  <div class="crossref__links">
    {registers.map(r => (
      <RegisterChip
        register={r}
        label={registerLabels[r]}
        href={`${base}/${r}`}
      />
    ))}
    {extra.map(e => (
      <a href={e.href} class="chip chip--neutral">{e.label}</a>
    ))}
  </div>
</div>
