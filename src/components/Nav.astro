---
import { useTranslations, type Lang } from '../i18n'
import Logo from './Logo.astro'

interface Props { lang: Lang }
const { lang } = Astro.props
const t = useTranslations(lang)
const base = `/${lang}`
const current = Astro.url.pathname
const otherLang = lang === 'en' ? 'fr' : 'en'
const langSwitchHref = current.replace(new RegExp(`^/${lang}(?=/|$)`), `/${otherLang}`)
---

<nav class="nav">
  <div class="container nav__inner">
    <a href={base} class="nav__logo">
      <Logo size={24} />
      Context Nexus
    </a>

    <ul class="nav__links">
      <li>
        <a href={`${base}/concepts`}
           aria-current={current.includes('/concepts') ? 'page' : undefined}>
          {t.nav.concepts}
        </a>
      </li>
      <li class="nav__dropdown">
        <a href={`${base}/registers/knowledge`}
           aria-current={current.includes('/registers/') ? 'page' : undefined}>
          {t.nav.registers}
        </a>
        <ul class="nav__submenu">
          <li>
            <a href={`${base}/registers/knowledge`} class="nav__sub-link nav__sub-link--knowledge">
              <span class="nav__sub-dot"></span>{t.nav.knowledge}
            </a>
          </li>
          <li>
            <a href={`${base}/registers/intent`} class="nav__sub-link nav__sub-link--intent">
              <span class="nav__sub-dot"></span>{t.nav.intent}
            </a>
          </li>
          <li>
            <a href={`${base}/registers/contracts`} class="nav__sub-link nav__sub-link--contracts">
              <span class="nav__sub-dot"></span>{t.nav.contracts}
            </a>
          </li>
          <li>
            <a href={`${base}/registers/operations`} class="nav__sub-link nav__sub-link--operations">
              <span class="nav__sub-dot"></span>{t.nav.operations}
            </a>
          </li>
        </ul>
      </li>
      <li>
        <a href={`${base}/implementation`}
           aria-current={current.includes('/implementation') ? 'page' : undefined}>
          {t.nav.implementation}
        </a>
      </li>
      <li>
        <a href={`${base}/example`}
           aria-current={current.includes('/example') ? 'page' : undefined}>
          {t.nav.example}
        </a>
      </li>
      <li>
        <a href={langSwitchHref} class="nav__lang">{t.nav.langLabel}</a>
      </li>
      <li>
        <button class="theme-toggle" id="theme-toggle" aria-label="Toggle colour theme">
          <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
          </svg>
          <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
      </li>
    </ul>

    <button class="nav__burger" id="nav-burger" aria-expanded="false" aria-label="Open menu">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </div>
</nav>

<div class="nav__overlay" id="nav-overlay" aria-hidden="true"></div>

<div class="nav__drawer" id="nav-drawer" aria-hidden="true">
  <div class="nav__drawer-header">
    <a href={base} class="nav__logo">
      <Logo size={24} />
      Context Nexus
    </a>
    <button class="nav__drawer-close" id="nav-drawer-close" aria-label="Close menu">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <ul class="nav__drawer-links">
    <li>
      <a href={`${base}/concepts`}
         aria-current={current.includes('/concepts') ? 'page' : undefined}>
        {t.nav.concepts}
      </a>
    </li>
    <li>
      <span class="nav__drawer-section">{t.nav.registers}</span>
      <ul class="nav__drawer-links nav__drawer-sub" style="gap: 0.1rem">
        <li>
          <a href={`${base}/registers/knowledge`} class="nav__sub-link nav__sub-link--knowledge"
             aria-current={current === `${base}/registers/knowledge` ? 'page' : undefined}>
            <span class="nav__sub-dot"></span>{t.nav.knowledge}
          </a>
        </li>
        <li>
          <a href={`${base}/registers/intent`} class="nav__sub-link nav__sub-link--intent"
             aria-current={current === `${base}/registers/intent` ? 'page' : undefined}>
            <span class="nav__sub-dot"></span>{t.nav.intent}
          </a>
        </li>
        <li>
          <a href={`${base}/registers/contracts`} class="nav__sub-link nav__sub-link--contracts"
             aria-current={current === `${base}/registers/contracts` ? 'page' : undefined}>
            <span class="nav__sub-dot"></span>{t.nav.contracts}
          </a>
        </li>
        <li>
          <a href={`${base}/registers/operations`} class="nav__sub-link nav__sub-link--operations"
             aria-current={current === `${base}/registers/operations` ? 'page' : undefined}>
            <span class="nav__sub-dot"></span>{t.nav.operations}
          </a>
        </li>
      </ul>
    </li>
    <li>
      <a href={`${base}/implementation`}
         aria-current={current.includes('/implementation') ? 'page' : undefined}>
        {t.nav.implementation}
      </a>
    </li>
    <li>
      <a href={`${base}/example`}
         aria-current={current.includes('/example') ? 'page' : undefined}>
        {t.nav.example}
      </a>
    </li>
  </ul>

  <div class="nav__drawer-footer">
    <a href={langSwitchHref} class="nav__lang">{t.nav.langLabel}</a>
    <button class="theme-toggle" id="theme-toggle-drawer" aria-label="Toggle colour theme">
      <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
      </svg>
      <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
  </div>
</div>

<script>
  function toggleTheme() {
    const next = document.documentElement.dataset.theme === 'light' ? 'dark' : 'light';
    document.documentElement.dataset.theme = next;
    localStorage.setItem('theme', next);
  }

  document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
  document.getElementById('theme-toggle-drawer')?.addEventListener('click', toggleTheme);

  const burger = document.getElementById('nav-burger');
  const overlay = document.getElementById('nav-overlay');
  const drawer = document.getElementById('nav-drawer');
  const closeBtn = document.getElementById('nav-drawer-close');

  function openDrawer() {
    drawer?.classList.add('is-open');
    overlay?.classList.add('is-open');
    drawer?.removeAttribute('aria-hidden');
    overlay?.removeAttribute('aria-hidden');
    burger?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    drawer?.classList.remove('is-open');
    overlay?.classList.remove('is-open');
    drawer?.setAttribute('aria-hidden', 'true');
    overlay?.setAttribute('aria-hidden', 'true');
    burger?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  burger?.addEventListener('click', openDrawer);
  overlay?.addEventListener('click', closeDrawer);
  closeBtn?.addEventListener('click', closeDrawer);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeDrawer();
  });
</script>

<style>
  .nav__dropdown { position: relative; }

  .nav__submenu {
    display: none;
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 0.5rem;
    list-style: none;
    min-width: 180px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    z-index: 200;
  }

  .nav__dropdown:hover .nav__submenu,
  .nav__dropdown:focus-within .nav__submenu {
    display: block;
  }

  .nav__submenu::before {
    content: '';
    position: absolute;
    top: -0.5rem;
    left: 0;
    right: 0;
    height: 0.5rem;
  }

  .nav__sub-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem !important;
    border-radius: var(--radius-sm) !important;
    font-size: 0.85rem !important;
    color: var(--text-muted) !important;
  }

  .nav__sub-link:hover { color: var(--text) !important; }

  .nav__sub-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .nav__sub-link--knowledge .nav__sub-dot { background: var(--knowledge); }
  .nav__sub-link--intent    .nav__sub-dot { background: var(--intent); }
  .nav__sub-link--contracts .nav__sub-dot { background: var(--contracts); }
  .nav__sub-link--operations .nav__sub-dot { background: var(--operations); }
</style>
